# Kopieer dit bestand naar .env.local en vul de waarden in.
# De waarden staan in je Supabase-project onder Project Settings > API.

# Frontend (Vite). De anon-sleutel heeft alleen leesrechten en mag publiek zijn.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PostHog product-analytics (optioneel, draait naast Vercel Analytics).
# De project-API-sleutel mag publiek zijn. Leeg laten = analytics uit.
# Host standaard EU; alleen aanpassen als je project in de VS draait.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Alleen voor het check-/seed-script. De service-sleutel mag NOOIT in de
# frontend of in git terechtkomen; zet hem in GitHub als repository-secret.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Webpush (VAPID). Genereer eenmalig met: npx web-push generate-vapid-keys
# De publieke sleutel mag in de frontend (VITE_...); de privésleutel NOOIT.
# Zet de drie zonder VITE-prefix ook als GitHub repository-secrets.
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:jouw@adres.nl
