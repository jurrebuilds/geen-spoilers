# Kopieer dit bestand naar .env.local en vul de waarden in.
# De waarden staan in je Supabase-project onder Project Settings > API.

# Frontend (Vite). De anon-sleutel heeft alleen leesrechten en mag publiek zijn.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Alleen voor het check-/seed-script. De service-sleutel mag NOOIT in de
# frontend of in git terechtkomen; zet hem in GitHub als repository-secret.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Waar het contactformulier naartoe mailt (api/contact.js). Hoort als
# omgevingsvariabele in Vercel; lokaal alleen nodig met `vercel dev`.
# Geen VITE_-prefix: het adres mag nooit in de frontend-bundel komen.
CONTACT_EMAIL=
