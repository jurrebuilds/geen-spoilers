# Kopieer dit bestand naar .env.local en vul de waarden in.
# De waarden staan in je Supabase-project onder Project Settings > API.

# Frontend (Vite). De anon-sleutel heeft alleen leesrechten en mag publiek zijn.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PostHog product-analytics (optioneel, draait naast Vercel Analytics).
# De project-API-sleutel mag publiek zijn. Leeg laten = analytics uit.
# Host standaard EU; alleen aanpassen als je project in de VS draait.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Tikkie-doneerlink (optioneel). Vult de doneerregel onder de video en de
# steunkaart op de homepage. Leeg laten = beide blijven onzichtbaar. Een
# privé-Tikkie verloopt na een paar weken; plak dan gewoon een nieuwe link
# (in Vercel als env-var, zonder code-deploy).
VITE_TIKKIE_URL=

# Steunkaart in de wedstrijdlijst (optioneel). Zet een versienummer (bijv. 1)
# om de kaart te tonen onder de nieuwste beschikbare samenvatting; leeg laten
# = kaart uit. Wegklikken wordt per versie onthouden: hoog de waarde op (1 -> 2)
# en iedereen ziet de kaart nog één keer. Vite bakt env-vars in tijdens de
# build, dus aanpassen in Vercel vereist een redeploy.
VITE_STEUN_KAART=

# Tour de France-tab (optioneel). Zet 1 om de sportwissel (WK | Tour) in de
# header te tonen; leeg laten = alleen het WK, precies als voorheen. Seed
# eerst de etappes (npm run seed) en draai het Tour-blok uit
# supabase/schema.sql, anders is de Tour-lijst leeg.
VITE_TOUR=

# Alleen voor het check-/seed-script. De service-sleutel mag NOOIT in de
# frontend of in git terechtkomen; zet hem in GitHub als repository-secret.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optioneel. Deploy-hook waarmee het check-script Vercel opnieuw laat bouwen
# zodra er nieuwe data is (leeg laten = geen automatische rebuild). Zet hem ook
# als GitHub repository-secret.
VERCEL_DEPLOY_HOOK_URL=

# Optioneel, alleen voor tests: overschrijf de YouTube-feeds die het check-script
# afzoekt (kommagescheiden). Leeg laten gebruikt de standaard NOS Sport-feeds.
SPOILERVRIJ_FEEDS=

# Optioneel: playlist-ID van de NOS Tour de France-playlist. De kanaalfeed
# toont maar ~15 video's; tijdens de WK/Tour-overlap kan een etappevideo daar
# snel uit draaien. Met dit ID zoekt het check-script ook in die playlist.
SPOILERVRIJ_TOUR_PLAYLIST=

# Alleen voor het verrijk-script (npm run enrich): haalt stadion, weer bij aftrap
# en opstelling op via api-sports.io (gratis tier). Zet hem ook als GitHub
# repository-secret.
APISPORTS_KEY=

# Webpush (VAPID). Genereer eenmalig met: npx web-push generate-vapid-keys
# De publieke sleutel mag in de frontend (VITE_...); de privésleutel NOOIT.
# Zet de drie zonder VITE-prefix ook als GitHub repository-secrets.
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:jouw@adres.nl
